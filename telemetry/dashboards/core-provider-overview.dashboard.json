{
  "uid": "core-provider-overview",
  "title": "Core Provider Overview",
  "tags": ["core-provider", "otel", "provider-runtime"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus",
        "refresh": 1,
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Queue Depth",
      "datasource": "$datasource",
      "gridPos": { "h": 5, "w": 3, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(provider_runtime_reconcile_queue_depth) or vector(0)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "In Flight",
      "datasource": "$datasource",
      "gridPos": { "h": 5, "w": 3, "x": 3, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(provider_runtime_reconcile_in_flight) or vector(0)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Startup Success",
      "datasource": "$datasource",
      "gridPos": { "h": 5, "w": 3, "x": 6, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(provider_runtime_startup_success_total[$__rate_interval])) or vector(0)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Startup Failure",
      "datasource": "$datasource",
      "gridPos": { "h": 5, "w": 3, "x": 9, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(provider_runtime_startup_failure_total[$__rate_interval])) or vector(0)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Requeue After",
      "datasource": "$datasource",
      "gridPos": { "h": 5, "w": 3, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(provider_runtime_reconcile_requeue_after_total[$__rate_interval])) or vector(0)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Requeue Immediate",
      "datasource": "$datasource",
      "gridPos": { "h": 5, "w": 3, "x": 15, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(provider_runtime_reconcile_requeue_immediate_total[$__rate_interval])) or vector(0)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Requeue Error",
      "datasource": "$datasource",
      "gridPos": { "h": 5, "w": 3, "x": 18, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(provider_runtime_reconcile_requeue_error_total[$__rate_interval])) or vector(0)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Queue Requeues Total",
      "datasource": "$datasource",
      "gridPos": { "h": 5, "w": 3, "x": 21, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(provider_runtime_reconcile_queue_requeues_total[$__rate_interval])) or vector(0)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Queue Wait p95",
      "datasource": "$datasource",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(provider_runtime_reconcile_queue_wait_duration_seconds_bucket[$__rate_interval])))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 12 } },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Queue Work p95",
      "datasource": "$datasource",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(provider_runtime_reconcile_queue_work_duration_seconds_bucket[$__rate_interval])))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 12 } },
        "overrides": []
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Oldest Queue Item Age p95",
      "datasource": "$datasource",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(provider_runtime_reconcile_queue_oldest_item_age_seconds_bucket[$__rate_interval])))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 12 } },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Reconcile Duration p95",
      "datasource": "$datasource",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(provider_runtime_reconcile_duration_seconds_bucket[$__rate_interval])))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 12 } },
        "overrides": []
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "External Connect p95",
      "datasource": "$datasource",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 13 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(provider_runtime_external_connect_duration_seconds_bucket[$__rate_interval])))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 12 } },
        "overrides": []
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "External Observe p95",
      "datasource": "$datasource",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 13 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(provider_runtime_external_observe_duration_seconds_bucket[$__rate_interval])))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 12 } },
        "overrides": []
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Finalizer Add p95",
      "datasource": "$datasource",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 13 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(provider_runtime_finalizer_add_duration_seconds_bucket[$__rate_interval])))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 12 } },
        "overrides": []
      }
    },
    {
      "id": 16,
      "type": "bar gauge",
      "title": "Requeue Totals by Reason",
      "datasource": "$datasource",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (increase(provider_runtime_reconcile_queue_requeues_total[$__rate_interval]))"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Reconcile Success vs Failure Rate",
      "datasource": "$datasource",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "targets": [
        { "refId": "A", "expr": "rate(provider_runtime_reconcile_success_total[$__rate_interval])", "legendFormat": "success" },
        { "refId": "B", "expr": "rate(provider_runtime_reconcile_failure_total[$__rate_interval])", "legendFormat": "failure" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops/s", "custom": { "lineWidth": 2, "fillOpacity": 8 } },
        "overrides": []
      }
    }
  ]
}
